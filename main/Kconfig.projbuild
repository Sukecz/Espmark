menu "espmark"

config ESPMARK_BOARD_NAME
    string "Board name reported in benchmark output"
    default "unknown-board"
    help
        Human-readable board name, for example "Seeed Studio XIAO ESP32C6".

config ESPMARK_BOARD_VENDOR
    string "Board vendor reported in benchmark output"
    default "unknown-vendor"

config ESPMARK_MODULE_NAME
    string "Module name reported in benchmark output"
    default "unknown-module"

config ESPMARK_RUN_LABEL
    string "Optional run label"
    default "local"

config ESPMARK_CPU_REPEAT
    int "CPU benchmark repetitions"
    default 20
    range 3 200

config ESPMARK_CPU_INNER_ITERATIONS
    int "CPU benchmark inner loop iterations"
    default 25000
    range 1000 10000000

endmenu

