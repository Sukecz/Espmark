{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espmark.dev/schemas/result-bundle.schema.json",
  "title": "espmark result bundle",
  "type": "object",
  "required": ["schema_version", "firmware_version", "board", "build", "config", "results"],
  "properties": {
    "schema_version": {"type": "string"},
    "firmware_version": {"type": "string"},
    "run_label": {"type": "string"},
    "board": {
      "type": "object",
      "required": ["vendor", "name", "module", "soc", "revision"],
      "properties": {
        "vendor": {"type": "string"},
        "name": {"type": "string"},
        "module": {"type": "string"},
        "soc": {"type": "string"},
        "revision": {"type": "integer"}
      },
      "additionalProperties": true
    },
    "build": {
      "type": "object",
      "required": ["sdk", "sdk_version", "target"],
      "properties": {
        "sdk": {"type": "string"},
        "sdk_version": {"type": "string"},
        "target": {"type": "string"}
      },
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "required": ["cpu_freq_mhz", "free_rtos_hz", "flash_size_bytes"],
      "additionalProperties": true
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "category", "unit", "samples", "mean", "median", "stdev", "p95", "min", "max"],
        "properties": {
          "test_id": {"type": "string"},
          "category": {"type": "string"},
          "unit": {"type": "string"},
          "samples": {"type": "integer", "minimum": 1},
          "mean": {"type": "number"},
          "median": {"type": "number"},
          "stdev": {"type": "number"},
          "p95": {"type": "number"},
          "min": {"type": "number"},
          "max": {"type": "number"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

